@{
    ViewData["Title"] = "Create Service Request";
}

<h2>Create Service Request</h2>

<form method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Contract</label>
        <select name="contractId" class="form-control">
            <option value="">-- Select Contract --</option>
            @foreach (var contract in (ViewBag.Contracts as List<TechMove.Models.DTOs.ContractDto> ?? new()))
            {
                <option value="@contract.Id">
                    #@contract.Id — @contract.ClientName (@contract.Status)
                </option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        <input name="description" class="form-control" placeholder="Describe the service request" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Amount (USD)</label>
        <input name="usdAmount" type="number" step="0.01" min="0.01" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-primary">Create Request</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
