@model IEnumerable<TechMove.Models.DTOs.ServiceRequestDto>

@{
    ViewData["Title"] = "Service Requests";
}

<h2 class="mb-3">Service Requests</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Create Service Request</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Contract Id</th>
            <th>Description</th>
            <th>Cost (USD)</th>
            <th>Cost (ZAR)</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.ContractId</td>
                    <td>@item.Description</td>
                    <td>@item.CostUSD.ToString("F2")</td>
                    <td>@item.CostZAR.ToString("F2")</td>
                    <td>
                        @if (item.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else if (item.Status == "Approved")
                        {
                            <span class="badge bg-success">Approved</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@item.Status</span>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="6" class="text-center">No service requests found</td></tr>
        }
    </tbody>
</table>
