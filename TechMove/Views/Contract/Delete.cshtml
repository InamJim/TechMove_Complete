@model TechMove.Models.DTOs.ContractDto

@{
    ViewData["Title"] = "Delete Contract";
}

<h2>Delete Contract</h2>
<div class="alert alert-danger">Are you sure you want to delete this contract?</div>

<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.Id</dd>
    <dt class="col-sm-2">Client</dt>
    <dd class="col-sm-10">@Model.ClientName</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>
    <dt class="col-sm-2">Service Level</dt>
    <dd class="col-sm-10">@Model.ServiceLevel</dd>
    <dt class="col-sm-2">Start Date</dt>
    <dd class="col-sm-10">@Model.StartDate.ToShortDateString()</dd>
    <dt class="col-sm-2">End Date</dt>
    <dd class="col-sm-10">@Model.EndDate.ToShortDateString()</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
