@model IEnumerable<TechMove.Models.DTOs.ContractDto>

@{
    ViewData["Title"] = "Contracts";
}

<h2 class="mb-3">Contracts</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Create Contract</a>
</div>

<form asp-action="Search" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-2">
            <input name="clientId" class="form-control" placeholder="Client ID" />
        </div>
        <div class="col-md-2">
            <select name="status" class="form-control">
                <option value="">All Status</option>
                <option value="Draft">Draft</option>
                <option value="Active">Active</option>
                <option value="Expired">Expired</option>
                <option value="OnHold">OnHold</option>
            </select>
        </div>
        <div class="col-md-3">
            <input type="date" name="startDate" class="form-control" />
        </div>
        <div class="col-md-3">
            <input type="date" name="endDate" class="form-control" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Client</th>
            <th>Status</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Service Level</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.ClientName</td>
                <td>
                    @switch (item.Status)
                    {
                        case "Active":
                            <span class="badge bg-success">Active</span>
                            break;
                        case "Expired":
                            <span class="badge bg-danger">Expired</span>
                            break;
                        case "OnHold":
                            <span class="badge bg-warning text-dark">OnHold</span>
                            break;
                        default:
                            <span class="badge bg-secondary">@item.Status</span>
                            break;
                    }
                </td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>@item.ServiceLevel</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
